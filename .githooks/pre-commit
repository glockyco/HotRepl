#!/usr/bin/env bash
# Pre-commit hook — mirrors the CI pipeline so failures are caught locally.
# Install: git config core.hooksPath .githooks
set -euo pipefail

PROJECT="src/HotRepl.Core/HotRepl.Core.csproj"

echo "[pre-commit] Building..."
dotnet build "$PROJECT" --nologo -clp:ErrorsOnly -v quiet

echo "[pre-commit] Checking format..."
dotnet format "$PROJECT" --verify-no-changes --no-restore --verbosity quiet

echo "[pre-commit] All checks passed."
